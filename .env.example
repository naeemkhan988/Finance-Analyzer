# ============================================
# Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# --- Application ---
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-this-in-production
APP_HOST=0.0.0.0
APP_PORT=5000

# --- LLM Providers (Choose one or multiple) ---
# Groq (Free tier - recommended for speed)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (Free tier - recommended for large context)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Vector Store ---
FAISS_INDEX_PATH=./data/embeddings
FAISS_INDEX_NAME=financial_docs

# --- Document Processing ---
CHUNK_SIZE=512
CHUNK_OVERLAP=128
MAX_FILE_SIZE_MB=500
UPLOAD_FOLDER=./data/raw

# --- Database ---
DATABASE_URL=sqlite:///./data/app.db

# --- Authentication ---
# Admin API key for full access. If not set, one is auto-generated on
# first startup and printed to stdout. Set this to use a fixed key.
ADMIN_API_KEY=

# --- Semantic Cache ---
# Cosine similarity threshold for cache hits (0.0-1.0).
# Higher = stricter matching, fewer cache hits but more accurate.
CACHE_SIMILARITY_THRESHOLD=0.92

# How long cached responses remain valid before expiring.
CACHE_TTL_HOURS=24

# --- Rate Limiting ---
# Maximum requests per hour for free-tier API keys.
RATE_LIMIT_FREE_PER_HOUR=20

# Maximum requests per hour for pro-tier API keys.
RATE_LIMIT_PRO_PER_HOUR=200

# --- Streaming ---
# Enable Server-Sent Events streaming for query responses.
# When enabled, POST /api/query/stream returns a real-time token stream.
STREAM_ENABLED=true

# --- Caching ---
CACHE_TTL=3600
ENABLE_SEMANTIC_CACHE=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
